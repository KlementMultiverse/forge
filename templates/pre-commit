#!/bin/bash
# Forge pre-commit hook — REQ impact + test guard + auto-sync
# 1. Auto-syncs all pending changes (README, registry, etc.)
# 2. Blocks commits that remove REQ tags
# 3. Warns when scripts changed without test updates
# Installed by /forge Phase A Step S8

# Auto-sync — run all pending syncs before commit
AUTO_SYNC="$HOME/.claude/scripts/forge-auto-sync.sh"
if [ -f "$AUTO_SYNC" ]; then
    bash "$AUTO_SYNC" run 2>/dev/null
fi

# REQ impact check
IMPACT_SCRIPT="$HOME/.claude/scripts/req-impact-check.py"
if [ -f "$IMPACT_SCRIPT" ]; then
    python3 "$IMPACT_SCRIPT" --staged --update-state
    RC=$?
    if [ $RC -ne 0 ]; then
        exit $RC
    fi
fi

# Test guard — warn if scripts changed without test updates
TEST_GUARD="$HOME/.claude/scripts/forge-test-guard.sh"
if [ -f "$TEST_GUARD" ]; then
    bash "$TEST_GUARD" --changed 2>/dev/null
fi

exit 0
