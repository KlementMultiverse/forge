#!/bin/bash
# Forge pre-commit hook — REQ impact + test guard + auto-sync
# 1. Auto-syncs all pending changes (README, registry, etc.)
# 2. Blocks commits that remove REQ tags
# 3. Warns when scripts changed without test updates
# Installed by /forge Phase A Step S8

# Auto-sync — run all pending syncs before commit
AUTO_SYNC="$HOME/.claude/scripts/forge-auto-sync.sh"
if [ -f "$AUTO_SYNC" ]; then
    bash "$AUTO_SYNC" run 2>/dev/null
fi

# REQ impact check
IMPACT_SCRIPT="$HOME/.claude/scripts/req-impact-check.py"
if [ -f "$IMPACT_SCRIPT" ]; then
    python3 "$IMPACT_SCRIPT" --staged --update-state
    RC=$?
    if [ $RC -ne 0 ]; then
        exit $RC
    fi
fi

# Test guard — warn if scripts changed without test updates
TEST_GUARD="$HOME/.claude/scripts/forge-test-guard.sh"
if [ -f "$TEST_GUARD" ]; then
    bash "$TEST_GUARD" --changed 2>/dev/null
fi

# Registry auto-regeneration — if any tracked file changed, regenerate
REGISTRY_SCRIPT="$HOME/.claude/scripts/forge-registry.py"
REGISTRY_FILE="forge-registry.json"
if [ -f "$REGISTRY_SCRIPT" ] && [ -f "$REGISTRY_FILE" ]; then
    # Check if any script/command/template/hook/agent/rule changed in this commit
    TRACKED_CHANGES=$(git diff --cached --name-only 2>/dev/null | grep -cE "^(scripts/|commands/|templates/|agents/|rules/|docs/domain-)" || true)
    if [ "$TRACKED_CHANGES" -gt 0 ]; then
        # Compute checksum of current registry
        OLD_SUM=$(md5sum "$REGISTRY_FILE" 2>/dev/null | cut -d' ' -f1)
        # Regenerate
        python3 "$REGISTRY_SCRIPT" --regenerate 2>/dev/null
        NEW_SUM=$(md5sum "$REGISTRY_FILE" 2>/dev/null | cut -d' ' -f1)
        # If changed, auto-stage
        if [ "$OLD_SUM" != "$NEW_SUM" ]; then
            git add "$REGISTRY_FILE" docs/dependency-graph.md 2>/dev/null
            echo "[FORGE] Registry auto-regenerated and staged (tracked files changed)"
        fi
    fi
fi

exit 0
