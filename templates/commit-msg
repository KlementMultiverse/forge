#!/bin/bash
# Forge commit-msg hook — enforces issue-first workflow + conventional commits
# Every commit must reference a GitHub issue (#N) and use conventional commit format
# Installed by /forge Phase A Step S8

MSG=$(cat "$1")

# Allow merge commits
if echo "$MSG" | grep -qE "^Merge "; then
  exit 0
fi

# Allow initial commit (before any issues exist)
if echo "$MSG" | grep -qE "^initial commit|^Initial commit|^init:"; then
  exit 0
fi

FIRST_LINE=$(echo "$MSG" | head -1)

# Check for issue reference (#N)
if ! echo "$MSG" | grep -qE '#[0-9]+'; then
  echo ""
  echo "[FORGE] BLOCKED: Commit must reference a GitHub issue."
  echo "[FORGE] Add #N anywhere in your commit message."
  echo "[FORGE] Example: feat(scripts): add retry tracking #14"
  echo ""
  echo "[FORGE] No issue yet? Create one first:"
  echo "[FORGE]   gh issue create --title 'describe change' --label 'bug'"
  echo ""
  exit 1
fi

# Check conventional commit format: type(scope): subject
# Types: feat|fix|chore|docs|refactor|test|perf|ci|build|revert
# Scopes: scripts|agents|commands|templates|rules|hooks|docs
TYPES="feat|fix|chore|docs|refactor|test|perf|ci|build|revert"
SCOPES="scripts|agents|commands|templates|rules|hooks|docs"

# Must match type(scope): format — scope is REQUIRED
if ! echo "$FIRST_LINE" | grep -qE "^($TYPES)\(($SCOPES)\):"; then
  echo ""
  echo "[FORGE] BLOCKED: Commit must use conventional format with scope."
  echo "[FORGE] Format: type(scope): subject #N"
  echo "[FORGE]"
  echo "[FORGE] Types:  feat|fix|chore|docs|refactor|test|perf|ci|build|revert"
  echo "[FORGE] Scopes: scripts|agents|commands|templates|rules|hooks|docs"
  echo "[FORGE]"
  echo "[FORGE] Example: feat(scripts): add retry tracking #14"
  echo "[FORGE]          fix(agents): correct reviewer prompt #22"
  echo "[FORGE]          docs(docs): update architecture reference #30"
  echo ""
  exit 1
fi

exit 0
